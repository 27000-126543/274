# 数据库配置
DATABASE_URL=sqlite:///ip_protection.db
# DATABASE_URL=postgresql://user:password@localhost:5432/ip_protection

# Redis配置（用于缓存和任务队列）
REDIS_URL=redis://localhost:6379/0

# 相似度阈值
SIMILARITY_THRESHOLD=0.80

# 爬虫配置
MAX_CONCURRENT_SPIDERS=10
REQUEST_TIMEOUT=30
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# 电商平台配置
TAOBAO_ENABLED=true
JD_ENABLED=true
PDD_ENABLED=true
DOUYIN_ENABLED=true
XIAOHONGSHU_ENABLED=true

# 邮件配置（警告函发送）
SMTP_SERVER=smtp.company.com
SMTP_PORT=465
SMTP_USER=legal@company.com
SMTP_PASSWORD=your_password
SMTP_USE_SSL=true

# 系统配置
COMPANY_NAME=示例科技有限公司
LEGAL_DEPARTMENT_EMAIL=legal@company.com
LEGAL_DIRECTOR_EMAIL=director@company.com

# 证据存储路径
EVIDENCE_STORAGE_PATH=./evidence

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/ip_protection.log
